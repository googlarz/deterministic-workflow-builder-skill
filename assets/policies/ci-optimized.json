{
  "name": "ci-optimized",
  "description": "Policy for reproducible CI workflows with bounded retries and test-heavy validation.",
  "failure_policy": {
    "on_error": "stop",
    "max_retries": 1
  },
  "execution": {
    "max_parallel": 2,
    "allow_skips": false
  },
  "approval": {
    "required_for": ["publish"],
    "auto_use_once": true,
    "require_reason": true
  },
  "environment": {
    "network_mode": "inherit",
    "allowed_working_directories": ["."],
    "allowed_env": ["HOME", "PATH", "USER", "SHELL", "TMPDIR", "LANG", "LC_*", "CODEX_*"]
  },
  "tooling": {
    "allowlisted_commands": ["bash", "cat", "cp", "echo", "find", "git", "grep", "jq", "mkdir", "mv", "python3", "rm", "sed", "sleep", "sort", "touch", "xargs"]
  },
  "audit": {
    "enabled": true,
    "record_env": true,
    "record_commands": true
  }
}
